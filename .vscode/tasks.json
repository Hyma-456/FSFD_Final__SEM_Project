{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Frontend (Vite)",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "ResearchCollab"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:"
        }
      }
    },
    {
      "label": "Start Node.js Backend",
      "type": "shell",
      "command": "node backend/server.js",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "ResearchCollab"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Backend running"
        }
      }
    },
    {
      "label": "Start Spring Boot Backend",
      "type": "shell",
      "command": ".\\mvnw.cmd spring-boot:run",
      "options": { "cwd": "${workspaceFolder}/backend-spring" },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "ResearchCollab"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[INFO\\]",
          "endsPattern": "Started ResearchCollabApplication"
        }
      }
    },
    {
      "label": "🚀 Run Full Stack (Frontend + Node + Spring Boot)",
      "dependsOn": [
        "Start Spring Boot Backend",
        "Start Node.js Backend",
        "Start Frontend (Vite)"
      ],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "⚡ Quick Start (Frontend + Node Backend only)",
      "dependsOn": [
        "Start Node.js Backend",
        "Start Frontend (Vite)"
      ],
      "dependsOrder": "parallel",
      "group": "build",
      "presentation": {
        "reveal": "always"
      }
    }
  ]
}
